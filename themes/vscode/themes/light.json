	"semanticTokenColors": {
		"*.deprecated": { "strikethrough": true },
		"*.defaultLibrary": { "italic": true },
		"*.async": { "italic": true },
		"function": "#1D3F89",
		"method": "#1D3F89",
		"class": "#9B6E19",
		"interface": "#9B6E19",
		"enum": "#9B6E19",
		"type": "#9B6E19",
		"string": "#627F2F",
		"comment": { "foreground": "#796961", "italic": true },
		"parameter": { "italic": true }
	},
